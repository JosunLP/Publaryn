# Publaryn — Environment Configuration
# Copy to .env and fill in your values.
# All variables can also be set as environment variables.
# Variable separator is double-underscore (__) for nested config.

# ── Server ────────────────────────────────────────────────────
SERVER__BIND_ADDRESS=0.0.0.0:3000
SERVER__BASE_URL=http://localhost:3000
# Comma-separated browser origins allowed to call the API cross-origin.
# Leave empty to deny cross-origin browser access by default.
# Example: http://localhost:5173,https://packages.example.com
SERVER__CORS_ALLOWED_ORIGINS=

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE__URL=postgres://publaryn:publaryn_dev@localhost/publaryn
DATABASE__MAX_CONNECTIONS=20

# ── Auth ─────────────────────────────────────────────────────
# Generate a secure random secret: openssl rand -hex 32
AUTH__JWT_SECRET=change_me_in_production_at_least_32_chars
AUTH__JWT_TTL_SECONDS=3600
AUTH__SESSION_TTL_SECONDS=86400
AUTH__ISSUER=http://localhost:3000

# ── Object Storage (S3 / MinIO) ───────────────────────────────
STORAGE__ENDPOINT=http://localhost:9000
STORAGE__BUCKET=publaryn-artifacts
STORAGE__ACCESS_KEY=minioadmin
STORAGE__SECRET_KEY=minioadmin123
STORAGE__REGION=us-east-1

# ── Search (Meilisearch) ──────────────────────────────────────
SEARCH__URL=http://localhost:7700
SEARCH__API_KEY=dev_master_key

# ── Redis ─────────────────────────────────────────────────────
REDIS__URL=redis://localhost:6379

# ── Logging ──────────────────────────────────────────────────
RUST_LOG=info,publaryn=debug
