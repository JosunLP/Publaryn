{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "vite.config.ts",
    "tailwind.config.ts",
    "svelte.config.js"
  ]
}
